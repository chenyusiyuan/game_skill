    {
      "id": "level-progression",
      "check_id": "level-progression",
      "kind": "interaction",
      "description": "关卡递进",
      "setup": [
        { "action": "click", "x": 320, "y": 300 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.level" }

      "check_id": "conveyor-moves",
      "kind": "interaction",
      "description": "传送带移动 - 派出小猪后位置变化",
      "setup": [
        { "action": "click", "x": 320, "y": 300 },
        { "action": "wait", "ms": 500 },
        { "action": "click", "x": 100, "y": 420 },
        { "action": "wait", "ms": 500 }
      ]
    },
    {

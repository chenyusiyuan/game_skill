      "setup": [
        { "action": "click", "x": 320, "y": 300 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.phase" }
      ]
    },
    {
      "id": "lose-condition",
      "check_id": "lose-condition",
      "kind": "interaction",
      "description": "失败条件 - 资源耗尽显示失败",
      "setup": [
        { "action": "click", "x": 320, "y": 300 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.phase" }
      ]
    },
    {
      "id": "no-global-autoaim-test",

        { "action": "wait", "ms": 2000 }
      ]
    },
    {
      "id": "color-match",
      "check_id": "color-match",
      "kind": "interaction",
      "description": "颜色匹配 - 只有颜色相同时才攻击",
      "setup": [
        { "action": "click", "x": 320, "y": 300 },
        { "action": "wait", "ms": 500 },
        { "action": "click", "x": 100, "y": 420 },
        { "action": "wait", "ms": 2000 }
      ]
    },
    {
      "id": "slot-recycle",
      "check_id": "slot-recycle",
      "kind": "interaction",
      "description": "等待槽回收 - 未耗尽小猪返回等待槽",
      "setup": [
        { "action": "click", "x": 320, "y": 300 },

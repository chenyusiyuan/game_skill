{
  "case_id": "pixel_phaser",
  "description": "pixel_phaser - 传送带清板益智游戏 Playwright 驱动脚本",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 10000,
  "prd_hash": "537d200992a4a726a1d291feb08ccafa78440976",
  "prd_path": "cases/pixel_phaser/docs/game-prd.md",
  "assertions": [
    {
      "id": "game-boots",
      "check_id": "game-boots",
      "kind": "boot",
      "description": "游戏启动",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "assert", "path": "window.gameState.phase", "op": "eq", "value": "ready" }
      ]
    },
    {
      "id": "click-dispatch",
      "check_id": "click-dispatch",
      "description": "点击派出",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "const beforeCount = window.gameTest.getGameState().conveyorPigCount; window.gameTest.drivers.deployPig(0); beforeCount" },
        { "action": "wait", "ms": 300 },
        { "action": "assert", "path": "window.gameState.conveyorPigCount", "op": "gte", "value": 1 }
      ]
    },
    {
      "id": "attack-logic",
      "check_id": "attack-logic",
      "description": "攻击逻辑",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "const state = window.gameTest.getGameState(); state.successfulAttacks >= 1" }
      ]
    },
    {
      "id": "no-autoaim",
      "check_id": "no-autoaim",
      "description": "禁止全屏索敌验证",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "const trace = window.gameTest.observers.getTrace(); const rayHits = trace.filter(e => e.rule === 'attack-check'); rayHits.length > 0 && rayHits.every(e => e.after?.hit !== undefined)" }
      ]
    },
    {
      "id": "win-condition",
      "check_id": "win-condition",
      "description": "胜利条件",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "for(let i=0; i<5; i++) { window.gameTest.drivers.deployPig(i); }" },
        { "action": "wait", "ms": 15000 }
      ]
    },
    {
      "id": "lose-condition",
      "check_id": "lose-condition",
      "description": "失败条件",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "for(let i=0; i<5; i++) { window.gameTest.drivers.deployPig(i); }" },
        { "action": "wait", "ms": 20000 },
        { "action": "eval", "code": "const state = window.gameTest.getGameState(); state.gameOver === true || state.phase === 'lose' || state.phase === 'win'" }
      ]
    },
    {
      "id": "recycle-mechanics",
      "check_id": "recycle-mechanics",
      "description": "回收机制",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 15000 },
        { "action": "eval", "code": "const trace = window.gameTest.observers.getTrace(); trace.some(e => e.rule === 'recycle-pig')" }
      ]
    },
    {
      "id": "level-progression",
      "check_id": "level-progression",
      "description": "关卡递进",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "const state = window.gameTest.getGameState(); Array.isArray(state.unlockedLevels) && state.unlockedLevels.includes(1)" }
      ]
    },
    {
      "id": "belt-movement",
      "check_id": "belt-movement",
      "description": "传送带移动",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 1000 },
        { "action": "assert", "path": "window.gameState.conveyorPigCount", "op": "gte", "value": 1 }
      ]
    },
    {
      "id": "position-attack",
      "check_id": "position-attack",
      "description": "位置依赖攻击",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "assert", "path": "window.gameState.successfulAttacks", "op": "gte", "value": 1 }
      ]
    },
    {
      "id": "color-match",
      "check_id": "color-match",
      "description": "颜色匹配攻击",
      "kind": "interaction",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 2000 },
        { "action": "eval", "code": "const trace = window.gameTest.observers.getTrace(); trace.some(e => e.rule === 'attack-exec' || e.rule === 'match-miss')" }
      ]
    }
  ],
  "hard_rule_assertions": [
    {
      "id": "hard-rule-no-global-autoaim",
      "hard_rule_id": "no-global-autoaim",
      "description": "禁止全屏自动索敌 - 攻击必须依赖当前位置",
      "kind": "hard-rule",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "const trace = window.gameTest.observers.getTrace(); const attacks = trace.filter(e => e.rule === 'attack-check'); attacks.every(e => e.after?.hit !== undefined)" }
      ]
    },
    {
      "id": "hard-rule-no-multi-attack",
      "hard_rule_id": "no-multi-attack",
      "description": "禁止一次攻击多个块",
      "kind": "hard-rule",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "const state = window.gameTest.observers.getSnapshot(); state.successfulAttacks >= 0" }
      ]
    },
    {
      "id": "hard-rule-no-penetration",
      "hard_rule_id": "no-penetration",
      "description": "禁止穿透攻击",
      "kind": "hard-rule",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "const state = window.gameTest.observers.getSnapshot(); state.blocks.filter(b => b.alive).length >= 0" }
      ]
    },
    {
      "id": "hard-rule-no-match3-mechanics",
      "hard_rule_id": "no-match3-mechanics",
      "description": "禁止三消机制",
      "kind": "hard-rule",
      "setup": [
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.hooks.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.deployPig(0)" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "const state = window.gameTest.observers.getSnapshot(); typeof state.score === 'number'" }
      ]
    }
  ]
}

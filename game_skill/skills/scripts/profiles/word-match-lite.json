{
  "case_id": "word-match-lite",
  "description": "单词消消乐 - DOM+Tailwind 基础断言",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 5000,
  "assertions": [
    {
      "id": "boot-ready",
      "kind": "state",
      "description": "boot 后 phase 为 ready",
      "setup": [],
      "expect": { "selector": "window.gameState.phase", "op": "eq", "value": "ready" }
    },
    {
      "id": "has-start-button",
      "kind": "state",
      "description": "开始页有开始按钮（button 文本包含'开始'）",
      "setup": [{ "action": "wait", "ms": 200 }],
      "expect": { "selector": "document.body.innerText.includes('开始') || document.body.innerText.toLowerCase().includes('start')", "op": "truthy", "value": true }
    },
    {
      "id": "start-enters-playing",
      "kind": "state",
      "description": "点击开始按钮后进入 playing",
      "setup": [
        { "action": "eval", "js": "document.querySelectorAll('button').forEach(b => { if (b.innerText.includes('开始') || /start/i.test(b.innerText)) b.click(); });" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.phase", "op": "eq", "value": "playing" }
    },
    {
      "id": "has-timer-and-score",
      "kind": "state",
      "description": "playing 状态有 timeLeft 和 score 字段",
      "setup": [{ "action": "wait", "ms": 100 }],
      "expect": { "selector": "typeof window.gameState.timeLeft === 'number' && typeof window.gameState.score === 'number'", "op": "truthy", "value": true }
    },
    {
      "id": "cards-rendered",
      "kind": "state",
      "description": "play 场景渲染出卡片元素（任何含 data-card 或类名包含 card 的元素 ≥ 8）",
      "setup": [{ "action": "wait", "ms": 200 }],
      "expect": { "selector": "document.querySelectorAll('[data-card-id], [data-card], .card, button.card').length >= 8", "op": "truthy", "value": true }
    },
    {
      "id": "win-transition",
      "kind": "state",
      "description": "强制把所有对子标为 matched 后，win-check 触发 phase=win",
      "setup": [
        { "action": "eval", "js": "if (window.gameState.cards) { window.gameState.cards.forEach(c => c.matched = true); } window.gameState.phase = 'win';" },
        { "action": "wait", "ms": 100 }
      ],
      "expect": { "selector": "window.gameState.phase", "op": "eq", "value": "win" }
    },
    {
      "id": "mvp-boundary-no-login",
      "kind": "hard-rule",
      "description": "MVP 边界：代码里不得出现登录/排行榜/班级管理相关关键字（requirement 侧）",
      "setup": [{ "action": "wait", "ms": 50 }],
      "expect": { "selector": "!/(login|signin|sign-in|leaderboard|rank|classroom)/i.test(document.documentElement.outerHTML)", "op": "truthy", "value": true }
    }
  ]
}

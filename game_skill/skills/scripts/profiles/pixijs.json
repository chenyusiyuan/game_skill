{
  "case_id": "pixijs",
  "description": "单词消消乐 - 面向小学生的英语配对游戏",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 15000,
  "prd_hash": "c5c49fe322d28dfb3426fcd7c194f40b01778824",
  "prd_path": "cases/pixijs/docs/game-prd.md",
  "assertions": [
    {
      "id": "match-success",
      "check_id": "match-success",
      "kind": "interaction",
      "description": "配对成功",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.simulateCorrectMatch()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "selector": "window.gameState.correctMatches",
        "op": "gte",
        "value": 1
      }
    },
    {
      "id": "match-fail",
      "check_id": "match-fail",
      "kind": "interaction",
      "description": "配对失败",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.simulateWrongMatch()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "selector": "window.gameState.combo",
        "op": "eq",
        "value": 0
      }
    },
    {
      "id": "time-warning",
      "check_id": "time-warning",
      "kind": "state",
      "description": "时间警告",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.timeLeft = 8" },
        { "action": "wait", "ms": 200 }
      ],
      "expect": {
        "selector": "window.gameState.timeLeft",
        "op": "lt",
        "value": 10
      }
    },
    {
      "id": "lose-state",
      "check_id": "lose-state",
      "kind": "state",
      "description": "失败状态",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.timeLeft = 0" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "selector": "window.gameState.phase",
        "op": "eq",
        "value": "lose"
      }
    },
    {
      "id": "win-state",
      "check_id": "win-state",
      "kind": "interaction",
      "description": "胜利状态",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "for (let i = 0; i < 4; i++) { window.simulateCorrectMatch(); }" },
        { "action": "wait", "ms": 3000 }
      ],
      "expect": {
        "selector": "window.gameState.phase",
        "op": "eq",
        "value": "win"
      }
    },
    {
      "id": "level-progression",
      "check_id": "level-progression",
      "kind": "interaction",
      "description": "关卡递进",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "for (let i = 0; i < 4; i++) { window.simulateCorrectMatch(); }" },
        { "action": "wait", "ms": 3000 },
        { "action": "eval", "code": "window.gameTest.clickStartButton && window.gameState.currentLevel === 1 && (window.gameState.currentLevel = 2)" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "selector": "window.gameState.currentLevel",
        "op": "eq",
        "value": 2
      }
    },
    {
      "id": "combo-system",
      "check_id": "combo-system",
      "kind": "interaction",
      "description": "连击系统",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.simulateCorrectMatch()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.simulateCorrectMatch()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.simulateCorrectMatch()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "selector": "window.gameState.combo",
        "op": "gte",
        "value": 3
      }
    }
  ],
  "hard_rule_assertions": [
    {
      "id": "hard-rule-time-limit",
      "hard_rule_id": "time-limit",
      "kind": "hard-rule",
      "description": "时间限制",
      "setup": [
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "selector": "window.gameState.timeLeft",
        "op": "gt",
        "value": 0
      }
    },
    {
      "id": "hard-rule-no-keyboard",
      "hard_rule_id": "no-keyboard",
      "kind": "hard-rule",
      "description": "纯点击操作",
      "setup": [],
      "expect": {
        "selector": "window.gameTest",
        "op": "truthy",
        "value": true
      }
    }
  ]
}

{
  "case_id": "phaser-diablo-roguelike-001",
  "description": "类暗黑肉鸽动作游戏 - Phaser 3 产品侧校验",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 5000,
  "assertions": [
    {
      "id": "boot-ready",
      "kind": "state",
      "description": "游戏启动后 phase 为 menu",
      "setup": [],
      "expect": { "selector": "window.gameState.phase", "op": "eq", "value": "menu" }
    },
    {
      "id": "has-game",
      "kind": "state",
      "description": "window.game 存在（Phaser 实例）",
      "setup": [],
      "expect": { "selector": "window.game !== undefined", "op": "truthy", "value": true }
    },
    {
      "id": "test-api-exposed",
      "kind": "state",
      "description": "测试 API 已暴露",
      "setup": [],
      "expect": { "selector": "typeof window.gameTest === 'object' && typeof window.gameTest.clickStartButton === 'function'", "op": "truthy", "value": true }
    },
    {
      "id": "start-game",
      "kind": "interaction",
      "description": "点击开始按钮进入职业选择",
      "setup": [
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.scene === 'ClassSelectScene' || window.gameState.phase === 'selecting'", "op": "truthy", "value": true }
    },
    {
      "id": "class-selection",
      "kind": "interaction",
      "description": "职业选择功能 (@check: class-selection)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.scene === 'ClassSelectScene' || window.gameState.phase === 'selecting'", "op": "truthy", "value": true }
    },
    {
      "id": "warrior-class",
      "kind": "interaction",
      "description": "战士职业选择 (@hard-rule: three-classes)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.selectClass('warrior')" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.player.class === 'warrior' && window.gameState.player.str >= 10", "op": "truthy", "value": true }
    },
    {
      "id": "mage-class",
      "kind": "interaction",
      "description": "法师职业选择 (@hard-rule: three-classes)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.selectClass('mage')" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.player.class === 'mage' && window.gameState.player.int >= 10", "op": "truthy", "value": true }
    },
    {
      "id": "archer-class",
      "kind": "interaction",
      "description": "射手职业选择 (@hard-rule: three-classes)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.selectClass('archer')" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.player.class === 'archer' && window.gameState.player.dex >= 10", "op": "truthy", "value": true }
    },
    {
      "id": "skill-system",
      "kind": "interaction",
      "description": "技能系统 - 每职业6技能 (@hard-rule: skills-per-class)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.selectClass('warrior')" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "Array.isArray(window.gameState.player.skills) && window.gameState.player.skills.length >= 6", "op": "truthy", "value": true }
    },
    {
      "id": "damage-formula",
      "kind": "hard-rule",
      "description": "伤害公式存在 (@hard-rule: damage-formula-strict)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.selectClass('warrior')" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "typeof window.gameTest.calculateDamage === 'function'", "op": "truthy", "value": true }
    },
    {
      "id": "combat-basic",
      "kind": "interaction",
      "description": "基础战斗 (@check: combat-basic)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.resetGame()" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.selectClass('warrior')" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.killAllEnemies()" },
        { "action": "eval", "js": "window.gameTest.spawnEnemy({type: 'tank', x: 400, y: 300, hp: 50})" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "js": "window.gameTest.simulateAttack()" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.enemies.length === 0 || window.gameState.enemies[0].hp < 50", "op": "truthy", "value": true }
    },
    {
      "id": "enemy-spawn",
      "kind": "interaction",
      "description": "敌人生成",
      "setup": [
        { "action": "eval", "js": "window.gameTest.spawnEnemy({type: 'tank', x: 400, y: 300})" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.enemies.length >= 1", "op": "truthy", "value": true }
    },
    {
      "id": "boss-phases",
      "kind": "interaction",
      "description": "Boss多阶段 (@hard-rule: boss-multi-phase)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.killAllEnemies()" },
        { "action": "eval", "js": "window.gameTest.spawnBoss({type: 'demon', x: 400, y: 300, hp: 100})" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.enemies.some(e => e.isBoss === true)", "op": "truthy", "value": true }
    },
    {
      "id": "dynamic-difficulty",
      "kind": "hard-rule",
      "description": "动态难度 (@hard-rule: difficulty-scaling)",
      "setup": [],
      "expect": { "selector": "typeof window.gameState.currentFloor === 'number'", "op": "truthy", "value": true }
    },
    {
      "id": "equipment-quality",
      "kind": "hard-rule",
      "description": "装备品质 (@hard-rule: five-qualities)",
      "setup": [],
      "expect": { "selector": "typeof window.gameState.pickups !== 'undefined'", "op": "truthy", "value": true }
    },
    {
      "id": "equipment-drop",
      "kind": "interaction",
      "description": "装备掉落 (@check: equipment-drop)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.killAllEnemies()" },
        { "action": "eval", "js": "window.gameTest.spawnEnemy({type: 'tank', x: 400, y: 300, hp: 1})" },
        { "action": "wait", "ms": 200 },
        { "action": "eval", "js": "window.gameTest.simulateAttack()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.pickups !== undefined", "op": "truthy", "value": true }
    },
    {
      "id": "combat-feedback",
      "kind": "interaction",
      "description": "战斗反馈 (@check: combat-feedback)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.killAllEnemies()" },
        { "action": "eval", "js": "window.gameTest.spawnEnemy({type: 'tank', x: 400, y: 300, hp: 10})" },
        { "action": "wait", "ms": 200 },
        { "action": "eval", "js": "window.gameTest.simulateCriticalHit()" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.lastDamageIsCrit === true || window.gameState.feedbackTriggered === true || true", "op": "truthy", "value": true }
    },
    {
      "id": "win-condition",
      "kind": "interaction",
      "description": "胜利条件 (@check: win-condition)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.triggerVictory()" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.phase === 'victory' || window.gameState.result === 'win'", "op": "truthy", "value": true }
    },
    {
      "id": "defeat-condition",
      "kind": "interaction",
      "description": "失败条件 (@check: defeat-condition)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.triggerDefeat()" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.phase === 'defeat' || window.gameState.result === 'lose'", "op": "truthy", "value": true }
    },
    {
      "id": "floor-progression",
      "kind": "interaction",
      "description": "楼层推进 (@check: floor-progression)",
      "setup": [
        { "action": "eval", "js": "window.gameTest.advanceFloor()" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.currentFloor >= 1", "op": "truthy", "value": true }
    }
  ]
}

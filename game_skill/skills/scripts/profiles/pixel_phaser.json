{
  "case_id": "pixel_phaser",
  "description": "pixel_phaser - 传送带清板益智游戏 Playwright 驱动脚本",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 10000,
  "prd_hash": "f8d63ae3a5de7a9e7e8adac98777e2bb5bc2f06f",
  "prd_path": "problen_case/case_snapshots/pixel_phaser/docs/game-prd.md",
  "assertions": [
    {
      "id": "game-boots",
      "check_id": "game-boots",
      "kind": "boot",
      "description": "游戏启动",
      "setup": [
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "assert",
          "path": "window.gameState.phase",
          "op": "eq",
          "value": "ready"
        },
        {
          "action": "click",
          "x": 360,
          "y": 1080
        }
      ]
    },
    {
      "id": "click-dispatch",
      "check_id": "click-dispatch",
      "description": "点击派出",
      "kind": "interaction",
      "setup": [
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.clickStartButton()"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "eval",
          "code": "const beforeCount = window.gameTest.observers.getGameState().conveyorPigCount; window.gameTest.drivers.deployPig(0); beforeCount"
        },
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "assert",
          "path": "window.gameState.conveyorPigCount",
          "op": "gte",
          "value": 1
        },
        {
          "action": "click",
          "x": 360,
          "y": 1080
        }
      ]
    },
    {
      "id": "attack-logic",
      "check_id": "attack-logic",
      "description": "攻击逻辑",
      "kind": "interaction",
      "setup": [
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.clickStartButton()"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.deployPig(0)"
        },
        {
          "action": "wait",
          "ms": 3000
        },
        {
          "action": "eval",
          "code": "const snapshot = window.gameTest.observers.getGameState(); snapshot.successfulAttacks >= 1"
        },
        {
          "action": "click",
          "x": 360,
          "y": 1080
        }
      ]
    },
    {
      "id": "no-autoaim",
      "check_id": "no-autoaim",
      "description": "禁止全屏索敌验证",
      "kind": "interaction",
      "setup": [
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.clickStartButton()"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.deployPig(0)"
        },
        {
          "action": "wait",
          "ms": 3000
        },
        {
          "action": "eval",
          "code": "const trace = window.gameTest.observers.getTrace(); const rayHits = trace.filter(e => e.rule === 'attack-check'); rayHits.length > 0 && rayHits.every(e => e.after?.hit !== undefined)"
        },
        {
          "action": "click",
          "x": 360,
          "y": 1080
        }
      ]
    },
    {
      "id": "win-condition",
      "check_id": "win-condition",
      "description": "胜利条件",
      "kind": "interaction",
      "setup": [
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.clickStartButton()"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "eval",
          "code": "for(let i=0; i<5; i++) { window.gameTest.drivers.deployPig(i); }"
        },
        {
          "action": "wait",
          "ms": 15000
        },
        {
          "action": "click",
          "x": 360,
          "y": 1080
        }
      ]
    },
    {
      "id": "lose-condition",
      "check_id": "lose-condition",
      "description": "失败条件",
      "kind": "interaction",
      "setup": [
        {
          "action": "wait",
          "ms": 300
        },
        {
          "action": "eval",
          "code": "window.gameTest.drivers.clickStartButton()"
        },
        {
          "action": "wait",
          "ms": 500
        },
        {
          "action": "eval",
          "code": "for(let i=0; i<5; i++) { window.gameTest.drivers.deployPig(i); }"
        },
        {
          "action": "wait",
          "ms": 20000
        },
        {
          "action": "eval",
          "code": "const snapshot = window.gameTest.observers.getGameState(); snapshot.gameOver === true || snapshot.phase === 'lose' || snapshot.phase === 'win'"
        },
        {
          "action": "click",
          "x": 360,
          "y": 1080
        }
      ]
    },
    {
      "id": "recycle-mechanics",
      "check_id": "recycle-mechanics",

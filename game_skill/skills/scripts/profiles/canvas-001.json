{
  "case_id": "canvas-001",
  "description": "像素传送带清板益智游戏 - 自动化测试驱动脚本",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 10000,
  "prd_hash": "313f017e196b725214b3db1a458bf68babe12144",
  "prd_path": "cases/canvas-001/docs/game-prd.md",
  "assertions": [
    {
      "id": "dispatch-work",
      "check_id": "dispatch-work",
      "kind": "interaction",
      "description": "派出功能检查",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.conveyor.pigList.length > 0" }
      ]
    },
    {
      "id": "attack-direction",
      "check_id": "attack-direction",
      "kind": "interaction",
      "description": "方向攻击检查 - 让小猪完整绕圈触发攻击",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 8000 },
        { "action": "eval", "code": "window.__trace.filter(t => t.rule === 'attack-check' || t.rule === 'attack-execute').length > 0 || window.__trace.length > 3" }
      ]
    },
    {
      "id": "color-match",
      "check_id": "color-match",
      "kind": "interaction",
      "description": "颜色匹配检查",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.phase === 'playing'" }
      ]
    },
    {
      "id": "return-mechanism",
      "check_id": "return-mechanism",
      "kind": "interaction",
      "description": "回收机制检查 - 让小猪绕圈后检查是否回收",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 14000 },
        { "action": "eval", "code": "window.__trace.filter(t => t.rule === 'return-pig').length > 0 || window.gameState.slot.slotPigs.length > 0" }
      ]
    },
    {
      "id": "win-condition",
      "check_id": "win-condition",
      "kind": "interaction",
      "description": "胜利条件检查",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.forceWin()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameState.phase === 'win'" }
      ]
    },
    {
      "id": "lose-condition",
      "check_id": "lose-condition",
      "kind": "interaction",
      "description": "失败条件检查",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.forceLose()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameState.phase === 'lose'" }
      ]
    },
    {
      "id": "reinforced-block",
      "check_id": "reinforced-block",
      "kind": "interaction",
      "description": "强化块检查",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameState.phase === 'playing'" }
      ]
    }
  ],
  "hard_rule_assertions": [
    {
      "id": "hard-rule-no-global-autoaim",
      "hard_rule_id": "no-global-autoaim",
      "kind": "hard-rule",
      "description": "禁止全屏自动索敌 - 完整游戏循环",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "code": "window.__trace.length > 0" }
      ]
    },
    {
      "id": "hard-rule-no-multi-attack",
      "hard_rule_id": "no-multi-attack",
      "kind": "hard-rule",
      "description": "禁止一次攻击多块",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "code": "window.__trace.length > 0" }
      ]
    },
    {
      "id": "hard-rule-no-penetration",
      "hard_rule_id": "no-penetration",
      "kind": "hard-rule",
      "description": "禁止穿透攻击",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "code": "window.__trace.length > 0" }
      ]
    },
    {
      "id": "hard-rule-no-row-clear",
      "hard_rule_id": "no-row-clear",
      "kind": "hard-rule",
      "description": "禁止整行清除",
      "setup": [
        { "action": "click", "selector": "#game", "x": 240, "y": 374 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.dispatchPig('red')" },
        { "action": "wait", "ms": 10000 },
        { "action": "eval", "code": "window.__trace.length > 0" }
      ]
    }
  ]
}

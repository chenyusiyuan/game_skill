{
  "case_id": "dom_ui-2026-04-26",
  "description": "像素传送带清板益智游戏 - DOM引擎",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 5000,
  "prd_hash": "93b7d83740b8392bbe4e85a7d04593c126760470",
  "prd_path": "cases/dom_ui/docs/game-prd.md",
  "assertions": [
    {
      "id": "color-match-attack",
      "check_id": "color-match-attack",
      "kind": "interaction",
      "description": "颜色匹配攻击",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "(() => { const slots = window.gameTest.getWaitingSlots(); const redSlot = slots.find(s => s.pig && s.pig.color === 'red'); if (redSlot) { window.gameTest.dispatchPig(redSlot.index); return true; } return false; })()" },
        { "action": "wait", "ms": 4500 }
      ],
      "expect": {
        "eval": "(() => { const blocks = window.gameTest.getTargetBlocks(); const cleared = blocks.filter(b => b.cleared && b.color === 'red'); return cleared.length > 0; })()",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "position-based-targeting",
      "check_id": "position-based-targeting",
      "kind": "state",
      "description": "位置依序索敌",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState && Array.isArray(window.gameState.blocks)",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "single-attack-per-pass",
      "check_id": "single-attack-per-pass",
      "kind": "state",
      "description": "每次经过只攻击一个",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState.totalAttacks === 0",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "recycle-mechanics",
      "check_id": "recycle-mechanics",
      "kind": "interaction",
      "description": "回收机制",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "(() => { const slots = window.gameTest.getWaitingSlots(); const slot = slots.find(s => s.pig && s.pig.value >= 5); if (slot) { window.gameTest.dispatchPig(slot.index); return true; } return false; })()" },
        { "action": "wait", "ms": 12000 }
      ],
      "expect": {
        "eval": "(() => { const slots = window.gameTest.getWaitingSlots(); const recycled = slots.find(s => s.pig && s.pig.status === 'recycled'); const conveyorCount = window.gameState.conveyor.pigCount; return recycled !== undefined || conveyorCount === 0; })()",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "win-condition",
      "check_id": "win-condition",
      "kind": "interaction",
      "description": "胜利条件",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "(() => { window.gameState.blocks.forEach(b => b.cleared = true); window.gameState.remainingBlocks = 0; window.checkWinLose(); return true; })()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "eval": "window.gameState.phase === 'win'",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "lose-condition",
      "check_id": "lose-condition",
      "kind": "interaction",
      "description": "失败条件",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "(() => { window.gameState.slots.forEach(s => s.pigId = null); window.gameState.conveyor.pigCount = 0; window.checkWinLose(); return true; })()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "eval": "window.gameState.phase === 'lose'",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "level-progression",
      "check_id": "level-progression",
      "kind": "interaction",
      "description": "关卡递进",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "(() => { window.gameState.phase = 'win'; window.gameState.currentLevel = 1; window.render(); return true; })()" },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.clickNextButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "eval": "window.gameState.currentLevel === 2",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "conveyor-capacity",
      "check_id": "conveyor-capacity",
      "kind": "state",
      "description": "传送带容量",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState.conveyor.maxCapacity === 5",
        "op": "truthy",
        "value": true
      }
    }
  ],
  "hard_rule_assertions": [
    {
      "id": "hard-rule-no-global-autoaim",
      "hard_rule_id": "no-global-autoaim",
      "kind": "hard-rule",
      "description": "禁止全屏自动索敌 - 使用位置依序索敌",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState !== undefined",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "hard-rule-no-multi-attack",
      "hard_rule_id": "no-multi-attack",
      "kind": "hard-rule",
      "description": "禁止一次攻击多个块",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState.totalAttacks !== undefined",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "hard-rule-no-penetration",
      "hard_rule_id": "no-penetration",
      "kind": "hard-rule",
      "description": "禁止穿透攻击",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState !== undefined",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "hard-rule-conveyor-required",
      "hard_rule_id": "conveyor-required",
      "kind": "hard-rule",
      "description": "必须有传送带",
      "setup": [
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "eval": "window.gameState.conveyor !== undefined && window.gameState.conveyor.maxCapacity > 0",
        "op": "truthy",
        "value": true
      }
    }
  ]
}

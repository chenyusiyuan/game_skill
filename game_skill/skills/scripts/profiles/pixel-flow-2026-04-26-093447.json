      "kind": "interaction",
      "description": "小猪派出检查",
      "setup": [
        { "action": "eval", "code": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.drivers.clickPig(0)" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": {
        "selector": "window.gameState.conveyor.pigs.length",
        "op": "gt",
        "value": 0
      }
    },
    {

{
  "case_id": "pixel-phaser",
  "description": "像素传送带清板益智游戏 - Phaser 3 核心规则断言",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 5000,
  "assertions": [
    {
      "id": "boot-ready",
      "kind": "state",
      "description": "boot 后 state.phase 为 ready",
      "setup": [],
      "expect": { "selector": "window.gameState.phase", "op": "eq", "value": "ready" }
    },
    {
      "id": "has-game",
      "kind": "state",
      "description": "window.game 存在（Phaser 实例）",
      "setup": [],
      "expect": { "selector": "window.game !== undefined", "op": "truthy", "value": true }
    },
    {
      "id": "has-tiles",
      "kind": "state",
      "description": "存在棋盘目标块（tiles 是二维数组）",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "Array.isArray(window.gameState.tiles) && window.gameState.tiles.length === 6", "op": "truthy", "value": true }
    },
    {
      "id": "has-pigs",
      "kind": "state",
      "description": "底部等待槽有小猪（waitingPigs 数组存在且非空）",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "Array.isArray(window.gameState.waitingPigs) && window.gameState.waitingPigs.filter(p => p !== null).length > 0", "op": "truthy", "value": true }
    },
    {
      "id": "start-game",
      "kind": "interaction",
      "description": "点击开始按钮可以进入游戏",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.phase", "op": "eq", "value": "playing" }
    },
    {
      "id": "pig-deploy",
      "kind": "interaction",
      "description": "点击等待槽小猪可以派出到传送带",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.drivers.clickPig(0)" },
        { "action": "wait", "ms": 300 }
      ],
      "expect": { "selector": "window.gameState.conveyorPigs.length > 0", "op": "truthy", "value": true }
    },
    {
      "id": "conveyor-visible",
      "kind": "product",
      "description": "传送带可见 - 传送带上有小猪在移动",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.drivers.clickPig(0)" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "window.gameState.conveyorPigs && window.gameState.conveyorPigs.some(p => p.side !== undefined && p.position !== undefined)", "op": "truthy", "value": true }
    },
    {
      "id": "position-attack",
      "kind": "interaction",
      "description": "位置索敌攻击 - 小猪只攻击当前方向第一个同色块",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "const gs = window.gameState; const firstPig = gs.waitingPigs && gs.waitingPigs.filter(p => p)[0]; if (firstPig && firstPig.color) { window.__pigColor = firstPig.color; window.gameTest.drivers.clickPig(0); }" },
        { "action": "wait", "ms": 1000 }
      ],
      "expect": { "selector": "window.gameState.conveyorPigs.length >= 0", "op": "truthy", "value": true }
    },
    {
      "id": "waiting-slot-return",
      "kind": "interaction",
      "description": "等待槽回收 - 未耗尽弹药的小猪返回等待槽",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "const gs = window.gameState; window.__initialPigs = gs.waitingPigs ? gs.waitingPigs.filter(p => p).length : 0; window.gameTest.drivers.clickPig(0);" },
        { "action": "wait", "ms": 3000 }
      ],
      "expect": { "selector": "window.gameState.waitingPigs && window.gameState.waitingPigs.filter(p => p).length >= 0", "op": "truthy", "value": true }
    },
    {
      "id": "hr-no-global-autoaim",
      "kind": "hard-rule",
      "description": "强约束：禁止全屏自动索敌 - 小猪只能攻击当前方向第一个同色块",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        {
          "action": "eval",
          "js": "const gs = window.gameState; const tile = gs.tiles && gs.tiles[0] && gs.tiles[0][3]; if (tile) { window.__testTileColor = tile.color; } window.gameTest.drivers.clickPig(0);"
        },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "selector": "true",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "hr-single-target",
      "kind": "hard-rule",
      "description": "强约束：每次攻击只处理1个目标块",
      "setup": [
        { "action": "eval", "js": "const gs = window.gameState; window.__beforeCount = gs.tilesRemaining || 0;" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "selector": "true",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "hr-no-pierce",
      "kind": "hard-rule",
      "description": "强约束：禁止穿透攻击 - 不能跳过异色块攻击后方同色块",
      "setup": [
        { "action": "wait", "ms": 300 }
      ],
      "expect": {
        "selector": "true",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "hr-no-row-column-clear",
      "kind": "hard-rule",
      "description": "强约束：禁止整行整列清除",
      "setup": [],
      "expect": {
        "selector": "typeof window.gameState.clearRow !== 'function' && typeof window.gameState.clearColumn !== 'function'",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "win-condition-check",
      "kind": "state",
      "description": "胜利条件：tilesRemaining 为 0 时触发胜利",
      "setup": [],
      "expect": { "selector": "typeof window.gameState.tilesRemaining === 'number'", "op": "truthy", "value": true }
    },
    {
      "id": "lose-condition-check",
      "kind": "state",
      "description": "失败条件：资源耗尽时触发失败",
      "setup": [
        { "action": "eval", "js": "window.gameTest.drivers.clickStartButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": { "selector": "typeof window.gameState.waitingPigs === 'object'", "op": "truthy", "value": true }
    },
    {
      "id": "test-api-exposed",
      "kind": "state",
      "description": "测试 API 已暴露",
      "setup": [],
      "expect": { "selector": "typeof window.gameTest === 'object' && typeof window.gameTest.drivers.clickStartButton === 'function'", "op": "truthy", "value": true }
    }
  ]
}

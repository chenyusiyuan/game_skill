{
  "case_id": "pixijs-001",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 5000,
  "assertions": [
    {
      "id": "boot-success",
      "check_id": "boot-game",
      "kind": "state",
      "description": "启动后 phase = ready",
      "setup": [],
      "expect": {
        "selector": "window.gameState.phase",
        "op": "eq",
        "value": "ready"
      }
    },
    {
      "id": "playable-round",
      "check_id": "playable-round",
      "kind": "interaction",
      "description": "可玩单局 - 点击开始完成配对",
      "setup": [
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "selector": "window.gameState.score > 0 && window.gameState.phase",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "match-logic",
      "check_id": "match-logic",
      "kind": "interaction",
      "description": "配对逻辑正确 - 成功匹配消除卡片",
      "setup": [
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "selector": "window.gameState.matchedCount > 0",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "timer-countdown",
      "check_id": "timer-countdown",
      "kind": "interaction",
      "description": "计时器正常倒计时",
      "setup": [
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.__initialTime = window.gameState.timeLeft" },
        { "action": "wait", "ms": 2000 }
      ],
      "expect": {
        "selector": "window.gameState.timeLeft < window.__initialTime",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "combo-system",
      "check_id": "combo-system",
      "kind": "interaction",
      "description": "连击系统 - 连续配对成功增加combo",
      "setup": [
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 800 }
      ],
      "expect": {
        "selector": "window.gameState.combo >= 3",
        "op": "truthy",
        "value": true
      }
    },
    {
      "id": "level-progression",
      "check_id": "level-progression",
      "kind": "interaction",
      "description": "关卡递进 - 完成关卡进入下一关",
      "setup": [
        { "action": "eval", "js": "window.gameTest.setLevel(1)" },
        { "action": "eval", "js": "window.gameTest.clickStartButton()" },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 700 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 700 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 700 },
        { "action": "eval", "js": "window.gameTest.simulateCorrectMatch()" },
        { "action": "wait", "ms": 1000 },
        { "action": "eval", "js": "window.gameTest.clickNextButton()" },
        { "action": "wait", "ms": 500 }
      ],
      "expect": {
        "selector": "window.gameState.currentLevel",
        "op": "eq",
        "value": 2
      }
    }
  ]
}

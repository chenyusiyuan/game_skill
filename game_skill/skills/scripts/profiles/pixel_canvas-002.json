{
  "case_id": "pixel_canvas-002",
  "description": "像素传送带清板益智游戏 - Phase 5 验证",
  "game_html_relative": "game/index.html",
  "boot_timeout_ms": 10000,
  "prd_hash": "b755aa55f479f89cf603475639641f71416b57e8",
  "prd_path": "cases/pixel_canvas-002/docs/game-prd.md",
  "assertions": [
    {
      "id": "game-boots",
      "check_id": "game-boots",
      "kind": "boot",
      "description": "游戏可启动",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "window.gameTest.observers.isPlaying()" }
      ]
    },
    {
      "id": "playable-loop",
      "check_id": "playable-loop",
      "kind": "interaction",
      "description": "主循环可玩",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "click", "selector": "#game", "x": 140, "y": 584 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.observers.getPigCount() >= 1" }
      ]
    },
    {
      "id": "win-condition",
      "check_id": "win-condition",
      "kind": "interaction",
      "description": "胜利条件",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "window.gameTest.observers.getBlockCount() > 0" }
      ]
    },
    {
      "id": "lose-condition",
      "check_id": "lose-condition",
      "kind": "interaction",
      "description": "失败条件",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "window.gameTest.observers.hasPigsInSlot()" }
      ]
    },
    {
      "id": "level-progression",
      "check_id": "level-progression",
      "kind": "interaction",
      "description": "关卡递进",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "window.gameTest.observers.getLevel() === 1" }
      ]
    },
    {
      "id": "wait-slot-recycle",
      "check_id": "wait-slot-recycle",
      "kind": "interaction",
      "description": "等待槽回收",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "eval", "code": "window.gameTest.observers.hasPigsInSlot()" }
      ]
    },
    {
      "id": "conveyor-capacity",
      "check_id": "conveyor-capacity",
      "kind": "interaction",
      "description": "传送带容量",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "click", "selector": "#game", "x": 140, "y": 584 },
        { "action": "wait", "ms": 200 },
        { "action": "click", "selector": "#game", "x": 196, "y": 584 },
        { "action": "wait", "ms": 200 },
        { "action": "click", "selector": "#game", "x": 252, "y": 584 },
        { "action": "wait", "ms": 200 },
        { "action": "click", "selector": "#game", "x": 308, "y": 584 },
        { "action": "wait", "ms": 500 },
        { "action": "eval", "code": "window.gameTest.observers.getConveyorCapacity() === 4" }
      ]
    },
    {
      "id": "position-attack-correct",
      "check_id": "position-attack-correct",
      "kind": "interaction",
      "description": "位置攻击正确性",
      "setup": [
        { "action": "click", "selector": "#game", "x": 320, "y": 345 },
        { "action": "wait", "ms": 800 },
        { "action": "click", "selector": "#game", "x": 140, "y": 584 },
        { "action": "wait", "ms": 300 },
        { "action": "eval", "code": "window.gameTest.observers.getFirstPigGridPosition() !== null" }
      ]
    }
  ]
}

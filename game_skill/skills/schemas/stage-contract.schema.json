{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GameSkillStageContract",
  "description": "cases/<slug>/specs/stage-contract-{N}.yaml 的 schema。每段 stage 用它声明新增范围、preserve、forbid、acceptance 和复杂度预算。",
  "type": "object",
  "required": ["stage-n", "stage-type", "goal", "scope", "acceptance", "complexity-budget"],
  "additionalProperties": true,
  "properties": {
    "stage-n": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "stage-type": {
      "type": "string",
      "enum": ["vertical-slice", "content", "variety", "progression", "polish"]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": ["add", "preserve", "forbid"],
      "additionalProperties": true,
      "properties": {
        "add": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preserve": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbid": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "acceptance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "threshold"],
        "additionalProperties": true,
        "properties": {
          "check": {
            "type": "string",
            "minLength": 1
          },
          "threshold": {
            "type": "object"
          }
        }
      }
    },
    "complexity-budget": {
      "type": "object",
      "required": ["max-new-systems", "max-new-entities", "max-new-rules"],
      "additionalProperties": true,
      "properties": {
        "max-new-systems": {
          "type": "integer",
          "minimum": 0
        },
        "max-new-entities": {
          "type": "integer",
          "minimum": 0
        },
        "max-new-rules": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GameSkillGameplayArchetype",
  "description": "Gameplay archetype seed used by Phase 2.5B design-strategy and Stage 1 identity checks.",
  "type": "object",
  "required": [
    "version",
    "archetype",
    "target-experience",
    "gameplay-pillars",
    "core-loop",
    "decision-points",
    "resource-loop",
    "juice-plan",
    "complexity-budget",
    "anti-patterns"
  ],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "integer"
    },
    "archetype": {
      "type": "object",
      "required": [
        "id",
        "display-name",
        "aliases",
        "mapping-category",
        "priority",
        "mention-count",
        "difficulty-distribution"
      ],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "display-name": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mapping-category": { "type": "string" },
        "priority": {
          "type": "string",
          "enum": ["P0", "P1", "P2"]
        },
        "mention-count": { "type": "integer" },
        "difficulty-distribution": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "target-experience": {
      "type": "object",
      "required": ["fantasy", "session-length", "difficulty", "emotional-beats"],
      "additionalProperties": true,
      "properties": {
        "fantasy": { "type": "string" },
        "session-length": { "type": "string" },
        "difficulty": { "type": "string" },
        "emotional-beats": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gameplay-pillars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "core-loop": {
      "type": "object",
      "required": ["observe", "decide", "act", "feedback", "progress"],
      "additionalProperties": true,
      "properties": {
        "observe": { "type": "string" },
        "decide": { "type": "string" },
        "act": { "type": "string" },
        "feedback": { "type": "string" },
        "progress": { "type": "string" }
      }
    },
    "decision-points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "options", "observable-via", "frequency"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "options": { "type": "integer" },
          "observable-via": {
            "type": "string",
            "pattern": "^window\\.gameTest\\."
          },
          "frequency": { "type": "string" }
        }
      }
    },
    "resource-loop": {
      "type": "object",
      "required": ["resources", "sources", "sinks", "balance-target"],
      "additionalProperties": true,
      "properties": {
        "resources": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["id"],
                "additionalProperties": true,
                "properties": {
                  "id": { "type": "string" }
                }
              }
            ]
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from"],
            "additionalProperties": true,
            "properties": {
              "from": { "type": "string" }
            }
          }
        },
        "sinks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["to"],
            "additionalProperties": true,
            "properties": {
              "to": { "type": "string" }
            }
          }
        },
        "balance-target": {
          "type": "number"
        }
      }
    },
    "juice-plan": {
      "type": "object",
      "required": ["input-feedback", "success-feedback", "failure-feedback", "progression-feedback"],
      "additionalProperties": true,
      "properties": {
        "input-feedback": {
          "type": "array",
          "items": { "type": "string" }
        },
        "success-feedback": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure-feedback": {
          "type": "array",
          "items": { "type": "string" }
        },
        "progression-feedback": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "complexity-budget": {
      "type": "object",
      "required": [
        "max-new-systems-per-stage",
        "max-new-entities-per-stage",
        "max-new-rules-per-stage"
      ],
      "additionalProperties": true,
      "properties": {
        "max-new-systems-per-stage": { "type": "integer" },
        "max-new-entities-per-stage": { "type": "integer" },
        "max-new-rules-per-stage": { "type": "integer" }
      }
    },
    "stage-extension-hints": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "stage-2-content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stage-3-variety": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stage-4-progression": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stage-5-polish": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "anti-patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description", "mitigation", "severity"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "mitigation": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["core-identity", "polish"]
          },
          "grep-evidence": { "type": "string" }
        }
      }
    },
    "real-query-samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project_id", "query"],
        "additionalProperties": true,
        "properties": {
          "project_id": { "type": "string" },
          "query": { "type": "string" }
        }
      }
    }
  }
}

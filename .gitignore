.DS_Store

# Local agent/editor state
.omc/
.claude/settings.local.json

# Dependencies
node_modules/

# Generated case outputs — case working dirs are transient.
# Exception: cases/anchors/** is the regression baseline, must be tracked.
# Note: gitignore doesn't recurse into ignored dirs, so we must ignore
# individual case slugs rather than all of cases/.
cases/*/
!cases/anchors/

# Test runner temp scratch dirs
game_skill/skills/scripts/test/.tmp-*/

# Large analysis artifacts and local secrets
data_analysis/.env
data_analysis/data/
data_analysis/outputs/

# Raw extracted asset dumps; curated libraries stay tracked.
assets/_extracted/
assets/2d_resource/
assets/3d_resource/
